'github.com/gab-language/cgab@0.1.3'.use 'Io'

# fib.gab
# Recursive Fibonacci - tests raw message dispatch and arithmetic.
# No allocation, no concurrency. Establishes a dispatch baseline.
#
# Compare against: lua, python3, ruby

do_fib: .defcase {
  true:  n :: n
  false: n :: (n - 1).fib + (n - 2).fib
}

fib: .def (Numbers.t, () :: do
  (self < 2) .do_fib self
end)

36.fib.println
