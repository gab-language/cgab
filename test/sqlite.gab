sqlite := 'github.com/gab-language/cgab@0.0.5'.use 'csqlite'

db := sqlite.make('test.sqlite').unwrap

"Opened $.".sprintf(db).println

db.eval "CREATE DATABASE SampleDB;USE SampleDB;"

db.eval "CREATE TABLE Employees (
    EmployeeID INT PRIMARY KEY,
    FirstName VARCHAR(50),
    LastName VARCHAR(50),
    HireDate DATE
);"

db.eval "INSERT INTO Employees (EmployeeID, FirstName, LastName, HireDate) VALUES
(1, 'John', 'Doe', '2023-01-15'),
(2, 'Jane', 'Smith', '2023-02-20');"

res := [db.eval "SELECT * FROM Employees;"]
res.println

res := [
  db.eval(
    "SELECT * FROM Employees WHERE EmployeeID := 1;"
  )
]
res.println
