UI := 'github.com/gab-language/cgab@0.1.2' .use 'cui'
Transducers := 'github.com/gab-language/cgab@0.1.2' .use 'Transducers'

(app ev) := (Channels.make, Channels.make)

ui := UI.run(tui: ev app).unwrap

word_bank := 'test/gwordle' .use 'word_bank.csv'
valid_words := 'test/gwordle' .use 'valid_words.csv'

dog := 'test/gwordle' .use 'dog.jpg'

listify := (binary) :: do
  str := binary.as\string.unwrap

  str.to\stream\split('\n').collect []
end

dictify := (binary) :: do
  str := binary.as\string.unwrap

  words := str.to\stream\split('\n').collect []

  shp := Shapes.from(words)

  rec := shp.make()

  rec
end

word_bank := listify.(word_bank)

valid_words := dictify.(valid_words)

random_answer := () :: do
  word_bank.at(Numbers.int\between(0, word_bank.len)).unwrap
end

validate_word := (word) :: do
  valid_words.at(word).ok
end

SIZE := 48

Colors := {
  cl: 0x00000000
  bg: 0xff161821
  fg: 0xffcdd6f5
  bg\hl: 0xff272c42
  fg\hl: 0xffc6c8d1
  w: 0xffffffff
  r: 0xfff38ba9
  o: 0xfffab388
  y: 0xfff9e2b0
  g: 0xffa6e3a2
  b: 0xff89b4fb
  i: 0xff94e2d6
  v: 0xffcba6f8
}

# TODO: Only has one hardcoded answer
# TODO: Doesn't validate inputs from a list of valid 5-letter words.
# TODO: Handle duplicate letters properly

model := {
  guess: ""
  answer: random_answer.()
  guesses: []
  done: false:
}

dispatch\key: .defcase {
  backspace: (model) :: model.put_by(guess: x :: x.pop.unwrap_or '')
  space:     (model) :: model
  enter:     (model) :: do
    (model.guesses.len < 5)
      .then (_ :: do
        ((model.guess.len == 5) & validate_word.(model.guess))
          .then(_ :: do
            model
              .put_by(guesses: x :: x.push(model.guess))
              .put(done: model.guess == model.answer)
              .put(guess: '')
            end)
          .or model
      end)
      .or model
  end
}

dispatch\key: .def (model) :: do
  key := self.to\string
  model.put(guess: model.guess .+ key .slice 5)
end

dispatch: .defcase {
  tick: (model args) :: model
  mouse: (model args) :: model
  key:  (model args) :: do
    (type, key) := args.*
    key := key.to\message
    (type == up:)
      .then(() ::  key.dispatch\key(model))
      .or model
  end
}

controller := (model event args*) :: do 
  model := event.dispatch(model args)
  model
end

bg_for_hint := (model i ok c) :: do
  ok
    .then(_ :: do
      c.cond {
        c :: model.answer.at i .unwrap_or nil: == c 
        Colors.g

        c :: model.answer.has\sub c
        Colors.y

        else:
        Colors.r
      }
    end)
    .or(Colors.bg)
  
end

#
# NOTE
#
# You don't *need* ids here because our elements are always drawn in this order.
# However, this is more of coincidence here - and if we want
# the id to be really stable, we should do it ourselves.

HintRow := (model str id) :: do
  Ranges.make(4).map i :: [
    box:
    {
      id: '$#$'.sprintf(id i).to\message
      w: 100
      h: 100
      align\x: center:
      align\y: center:
      bg: bg_for_hint.(model i str.at i)
      border: { fg: Colors.bg, w: 9 }
      transition\duration: 2
    }
    [
      [
        text:
        {
          size: SIZE
          content: str.at i .unwrap_or " "
          bg: Colors.cl
          fg: Colors.bg
        }
      ]
    ]
  ]
end

Row := (str id) :: do
  Ranges.make(4).map i :: [
    box:
    {
      id: '$#$'.sprintf(id i).to\message
      w: 100
      h: 100
      align\x: center:
      align\y: center:
      bg: Colors.fg
      border: { fg: Colors.bg, w: 9 }
      transition\duration: 2
    }
    [
      [
        text:
        {
          size: SIZE
          content: str.at i .unwrap_or " "
          fg: Colors.bg
          bg: Colors.cl
        }
      ]
    ]
  ]
end

remaining := (model) :: do
 chances := 4 - model.guesses.len
 (chances > 0)
  .then(_ :: Ranges
    .make(chances - 1)
    .map(i :: [box: { layout: horizontal: } Row.("" model.guesses.len + i + 1)]))
  .or []
end

current_guess := (model) :: do
  (model.guesses.len < 5)
    .then(_ :: [[
        box:
        {
          bg: Colors.bg
          layout: horizontal:
        }
        Row.(model.guess, model.guesses.len)
      ]])
    .or []
end

view := (model) :: [
  [
    box:
    {
      w\g: 1
      bg: Colors.bg
      align\x: center:
    }
    [
      [text: { size: SIZE * 2 bg: Colors.bg, fg: Colors.b, content: "gwordle" }]
    ]
  ]
  [
    box: 
    {
      align\x: center:
      align\y: center:
      h\g: 1
      w\g: 1
      bg: Colors.bg
    }
    [
      model.guesses.map((g i) :: [box: { layout: horizontal: } HintRow.(model g i)])*
      current_guess.(model)*
      remaining.(model)*
    ]
  ]
]

ev
  .pipe(
    app
    Transducers.take_until((e t key) :: do
      (e == key:) & (key == "escape")
    end)
#|> Transducers.tap((args*) :: args.eprintln)
    |> Transducers.reduce(model controller)
#|> Transducers.tap((model) :: model.eprintln)
    |> Transducers.map(view))

app.close
ev.close
