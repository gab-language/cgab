s := 'github.com/gab-language/cgab@0.1.2'.use 'Specs'

json\to\json: .defspec {
  help:
  "
  Convert a value into a json string.
  "
  spec: s.message {
    receiver: s.unknown
    message:  to\json:
    input:    s.cat
    output:   s.string
  }
}

json\as\json: .defspec {
  help:
  "
  Try to parse a string as a json value.
  "
  spec: s.message {
    receiver: s.string
    message:  as\json:
    input:    s.cat
    output:   s.result(s.unknown, s.string)
  }
}
