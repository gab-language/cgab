s := 'github.com/gab-language/cgab@0.1.2'.use 'Specs'

dbrow: .defspec {
  help:
  "
  A connection to a row-based database. This implementation wraps sqlite.
  "
  spec: s.box 'db\row'
}

dbrow\eval: .defspec {
  help:
  "
  Evaluate the sql string argument against the database `self`.
  "
  spec: s.message {
    receiver: dbrow:
    input: s.string
    message: eval:
    output: s.result(s.cat(s.*(s.unknown)), s.string)
  }
}
