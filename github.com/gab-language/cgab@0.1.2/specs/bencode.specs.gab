s := 'github.com/gab-language/cgab@0.1.2'.use 'Specs'

bencode\to\bencode: .defspec {
  help:
  "
  Convert a value into a bencode string.
  "
  spec: s.message {
    receiver: s.unknown
    message:  to\bencode:
    input:    s.cat
    output:   s.string
  }
}

bencode\as\bencode: .defspec {
  help:
  "
  Try to parse a string as a bencode value.
  "
  spec: s.message {
    receiver: s.string
    message:  as\bencode:
    input:    s.cat
    output:   s.result(s.unknown, s.string)
  }
}
